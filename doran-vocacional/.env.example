# Chave usada somente pela Vercel Function. Nunca use prefixo VITE_.
GEMINI_API_KEY=

# Modelos podem ser alterados sem modificar o código.
DORAN_GEMINI_MODEL=gemini-2.5-flash
DORAN_GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Opcional. Em produção, mantenha vazio para usar a API no mesmo domínio.
# Use somente ao executar um backend separado em desenvolvimento.
VITE_DORAN_API_URL=
