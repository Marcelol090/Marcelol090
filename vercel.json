{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd doran-vocacional && npm install --no-audit --no-fund",
  "buildCommand": "cd doran-vocacional && npm run build",
  "outputDirectory": "doran-vocacional/dist",
  "functions": {
    "api/report.mjs": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; font-src 'self' data:; base-uri 'none'; form-action 'self'; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
